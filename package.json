{
    "name": "fidel-tools-monorepo",
    "version": "0.1.4",
    "private": true,
    "engines": {
        "node": ">=22.0.0"
    },
    "packageManager": "pnpm@10.28.0",
    "scripts": {
        "build": "pnpm --filter ./packages/core build && pnpm --filter ./packages/lang-am build && pnpm --filter ./apps/api build && pnpm --filter ./apps/web build",
        "dev": "pnpm --filter @fidel-tools/api dev & pnpm --filter @fidel-tools/web dev",
        "test": "pnpm --filter \"@fidel-tools/*\" test"
    },
    "devDependencies": {
        "typescript": "^5.0.4"
    }
}
